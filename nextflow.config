/*
 * nf-loxhd1 configuration
 * Profiles: -profile docker (recommended) | -profile conda | -profile test
 */

manifest {
    name            = 'nf-loxhd1'
    description     = 'Runnable subset of Hytönen et al. 2021 (canine LOXHD1 NSHL)'
    author          = 'reproduction pipeline'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

params {
    outdir = 'results'
}

profiles {

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    conda {
        conda.enabled          = true
        process {
            withName: 'PREPARE_REFERENCE|BAM_QC' { conda = 'bioconda::samtools=1.19' }
            withName: 'PREFETCH_BAM'             { conda = 'bioconda::sra-tools=3.1.1 bioconda::samtools=1.19' }
            withName: 'MARKDUP_ADDRG|CALL_VARIANTS' { conda = 'bioconda::gatk4=4.5.0.0 bioconda::samtools=1.19' }
            withName: 'DELLY_SV'                 { conda = 'bioconda::delly=1.2.6 bioconda::bcftools=1.19' }
            withName: 'ANNOTATE'                 { conda = 'bioconda::ensembl-vep=111.0' }
            withName: 'LOCUS_CHECK'              { conda = 'bioconda::bcftools=1.19' }
        }
    }

    test {
        params.wgs_srr = 'TEST_WGS'
        params.wes_srr = 'TEST_WES'
    }
}

// Process resource definitions

process {

    // Defaults for processes without specific settings
    cpus = 1
    memory = 2.GB
    time = 4.h

    withName: 'PREFETCH_BAM' {
        cpus = 1
        memory = 2.GB
        time = 8.h
    }

    withName: 'CALL_VARIANTS' {
        cpus = 4
        memory = 8.GB
        time = 12.h
    }

    withName: 'DELLY_SV' {
        cpus = 2
        memory = 4.GB
        time = 4.h
    }

    withName: 'ANNOTATE' {
        cpus = 2
        memory = 4.GB
        time = 2.h
    }

    withName: 'CALL_VARIANTS' {
    cpus = 2
    memory = 6.GB
    time = 12.h
    }
}

// Reporting – enable overwrite to avoid "file already exists" errors

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}